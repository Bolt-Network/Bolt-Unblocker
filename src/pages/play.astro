---
import Layout from "../Layouts/Layout.astro";
---

<Layout title="Play" proxy={false}>
    <main>
        <div id="ptop">
            <div id="game-container">
                <iframe id="game-frame" src="" allowfullscreen></iframe>
                <div id="ptoolbar">
                    <div id="game-info">
                        <button
                            id="back-btn"
                            aria-label="Back to games"
                            title="Back to games"
                            ><svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M15 19l-7-7 7-7"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg></button
                        >
                        <img id="game-icon" src="" alt="Game icon" />
                        <h1 id="game-title">Loading...</h1>
                    </div>
                    <div id="ptoolbar-buttons">
                        <button
                            id="fullscreen-btn"
                            aria-label="Toggle fullscreen"
                            title="Fullscreen (F11)"
                            ><svg
                                width="100%"
                                height="100%"
                                viewBox="0 0 24 24"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M8 3H7.8C6.11984 3 5.27976 3 4.63803 3.32698C4.07354 3.6146 3.6146 4.07354 3.32698 4.63803C3 5.27976 3 6.11984 3 7.8V8M8 21H7.8C6.11984 21 5.27976 21 4.63803 20.673C4.07354 20.3854 3.6146 19.9265 3.32698 19.362C3 18.7202 3 17.8802 3 16.2V16M21 8V7.8C21 6.11984 21 5.27976 20.673 4.63803C20.3854 4.07354 19.9265 3.6146 19.362 3.32698C18.7202 3 17.8802 3 16.2 3H16M21 16V16.2C21 17.8802 21 18.7202 20.673 19.362C20.3854 19.9265 19.9265 20.3854 19.362 20.673C18.7202 21 17.8802 21 16.2 21H16"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg></button
                        >
                        <button
                            id="reload-btnp"
                            aria-label="Reload game"
                            title="Reload game"
                            ><svg
                                width="100%"
                                height="100%"
                                viewBox="0 0 24 24"
                                fill="none"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path
                                    d="M2 10C2 10 4.00498 7.26822 5.63384 5.63824C7.26269 4.00827 9.5136 3 12 3C16.9706 3 21 7.02944 21 12C21 16.9706 16.9706 21 12 21C7.89691 21 4.43511 18.2543 3.35177 14.5M2 10V4M2 10H8"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg></button
                        >
                    </div>
                </div>
            </div>
        </div>
        <script src="../scripts/play.ts"></script>
    </main>
</Layout>
